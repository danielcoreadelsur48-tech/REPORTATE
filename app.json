{
  "expo": {
    "name": "REPÓRTATE",
    "slug": "reportate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "reportate",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1A56DB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reportate.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "REPÓRTATE necesita tu ubicación para registrar el fin de jornada y enviar alertas SOS.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "REPÓRTATE necesita tu ubicación en segundo plano para el seguimiento de emergencias SOS.",
        "NSUserNotificationsUsageDescription": "REPÓRTATE necesita enviarte notificaciones sobre el estado de tu grupo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1A56DB"
      },
      "package": "com.reportate.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A56DB",
          "image": "./assets/images/splash.png",
          "resizeMode": "cover",
          "dark": {
            "backgroundColor": "#1A56DB"
          }
        }
      ],
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "REPÓRTATE necesita tu ubicación para el seguimiento SOS.",
          "locationWhenInUsePermission": "REPÓRTATE necesita tu ubicación para registrar el fin de jornada."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1A56DB",
          "sounds": []
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/fb2b163c-997b-4b32-85fb-dd1ad93c6865"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fb2b163c-997b-4b32-85fb-dd1ad93c6865"
      }
    }
  }
}
